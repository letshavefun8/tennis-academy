rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ИГРОКИ =====
    // Читать профиль может любой аутентифицированный пользователь.
    // Писать в свой документ может только владелец (uid совпадает).
    // Поля валидируются по типу и разумным границам — чтобы бот не залил
    // в документ мусор или абсурдные значения. Проверяем «если поле есть»,
    // т.к. cloudSyncProfile пишет частичный набор через set(merge).
    match /players/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && (!('name' in request.resource.data)
            || (request.resource.data.name is string
                && request.resource.data.name.size() <= 40))
        && (!('points' in request.resource.data)
            || (request.resource.data.points is int
                && request.resource.data.points >= 0
                && request.resource.data.points <= 100000000))
        && (!('weeklyPoints' in request.resource.data)
            || (request.resource.data.weeklyPoints is int
                && request.resource.data.weeklyPoints >= 0
                && request.resource.data.weeklyPoints <= 100000000))
        && (!('bestStreakEver' in request.resource.data)
            || (request.resource.data.bestStreakEver is int
                && request.resource.data.bestStreakEver >= 0
                && request.resource.data.bestStreakEver <= 100000))
        && (!('daysCount' in request.resource.data)
            || (request.resource.data.daysCount is int
                && request.resource.data.daysCount >= 0
                && request.resource.data.daysCount <= 100000));
      // delete намеренно запрещён — защита от случайной или злонамеренной потери данных
    }

    // ===== ЛЕНТА СОБЫТИЙ (СТЕНА) =====
    // Читать может любой аутентифицированный.
    // Создавать можно только со своим uid; набор полей и их размеры строго
    // ограничены — лента публичная, это главная цель спама.
    // Редактировать и удалять нельзя.
    match /feed/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'name', 'type', 'text', 'emoji', 'ts'])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        && request.resource.data.type in ['block_stars', 'rank_up', 'daily_done']
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 200
        && request.resource.data.emoji is string
        && request.resource.data.emoji.size() <= 8
        && (request.resource.data.ts is timestamp || request.resource.data.ts is int);
      allow update: if false;
      allow delete: if false;
    }

  }
}
